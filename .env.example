COGNIWEAVE_LLM_PROVIDER=minimax_openai_compat
# MiniMax OpenAI-compatible config:
# Base URL must be https://api.minimaxi.com
# Do not put /anthropic here when using the current OpenAI SDK path.
MINIMAX_API_KEY=your_real_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com
MINIMAX_MODEL=MiniMax-M2.7
COGNIWEAVE_LLM_TEMPERATURE=0.2
COGNIWEAVE_LLM_MAX_COMPLETION_TOKENS=2048

COGNIWEAVE_ENABLE_QDRANT=false
COGNIWEAVE_QDRANT_URL=http://localhost:6333
COGNIWEAVE_QDRANT_API_KEY=
COGNIWEAVE_QDRANT_COLLECTION_PREFIX=cogniweave

COGNIWEAVE_ENABLE_NEO4J=false
COGNIWEAVE_NEO4J_URI=neo4j://localhost:7687
COGNIWEAVE_NEO4J_USER=neo4j
COGNIWEAVE_NEO4J_PASSWORD=secretgraph

COGNIWEAVE_ENABLE_FORGET=false
COGNIWEAVE_FORGET_INTERVAL_SECONDS=1800
